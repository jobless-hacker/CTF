ENVIRONMENT=production
DATABASE_URL=postgresql://user:pass@host:5432/dbname
SECRET_KEY=change-me-to-a-long-random-string
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
DOMAIN=your-backend-domain.com
LAB_PRIVATE_FLAGS_FILE=config/seeds/private-flags.json
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_LOCK_SECONDS=60
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_REDIS_KEY_PREFIX=zerotrace:rate_limit
RATE_LIMIT_REDIS_SOCKET_TIMEOUT_MS=200
LAB_COMMAND_RATE_LIMIT_ENABLED=true
LAB_COMMAND_RATE_LIMIT_MAX_ATTEMPTS=30
LAB_COMMAND_RATE_LIMIT_WINDOW_SECONDS=60
LAB_COMMAND_RATE_LIMIT_LOCK_SECONDS=30
SEED_SYNC_WATCH_ENABLED=false
SEED_SYNC_WATCH_INTERVAL_SECONDS=2
SEED_SYNC_WATCH_DEBOUNCE_SECONDS=1
SEED_SYNC_SYNC_ON_STARTUP=true
SEED_SYNC_SEED_FILE=config/seeds/foundations-challenge-todo.seed.json
SEED_SYNC_FLAGS_FILE=config/seeds/private-flags.json
SEED_SYNC_MODULES_DIR=config/seeds/modules
